# ─── Recording Storage ────────────────────────────────────────────────────────
# Host directory where recordings are saved.
# Each stream gets its own sub-folder (STREAM_n_FOLDER).
RECORDINGS_DIR=/data/recordings

# How long each recording segment (file) should be before a new one is started.
# Format: Go duration string — e.g. 1h, 30m, 2h30m
RECORD_SEGMENT_DURATION=1h

# Delete old segments after this duration. Set to 0s to keep forever.
RECORD_DELETE_AFTER=0s

# ─── Stream Sources ────────────────────────────────────────────────────────────
# Add one block per device. Increment the index (1, 2, 3, …).
#
# STREAM_n_NAME   — path name inside mediamtx (no spaces)
# STREAM_n_SOURCE — RTSP/RTMP URL of the live stream to pull and record
# STREAM_n_FOLDER — sub-folder inside RECORDINGS_DIR for this stream's files
#                   (defaults to STREAM_n_NAME if omitted)

STREAM_1_NAME=first
STREAM_1_SOURCE=rtsp://100.86.162.126:8554/livestream
STREAM_1_FOLDER=first

# STREAM_2_NAME=microscope-feed
# STREAM_2_SOURCE=rtsp://192.168.1.101:8554/livestream
# STREAM_2_FOLDER=microscope-feed

# STREAM_3_NAME=reactor-camera
# STREAM_3_SOURCE=rtmp://192.168.1.102:1935/livestream
# STREAM_3_FOLDER=reactor-camera
