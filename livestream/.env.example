# ─── Recording Storage ────────────────────────────────────────────────────────
# Host directory where recordings are saved.
# Each stream is stored in a sub-folder named after STREAM_n_NAME.
RECORDINGS_DIR=/home/zhao/workspace/puda-logger/livestream/recordings

# Duration of each recording segment file before a new one starts.
# Format: Go duration string — e.g. 1h, 30m, 2h30m
RECORD_SEGMENT_DURATION=1h

# Delete old segments after this duration. Set to 0s to keep forever.
RECORD_DELETE_AFTER=0s