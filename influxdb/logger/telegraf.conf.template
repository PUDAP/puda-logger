[agent]
  interval = "10s"
  flush_interval = "5s"
  metric_batch_size = 1000
  metric_buffer_limit = 100000

# Command requests: puda.*.cmd.queue, puda.*.cmd.immediate
[[inputs.nats_consumer]]
  name_override = "commands"
  servers = ${NATS_SERVERS}
  subjects = ["puda.*.cmd.*"]
  queue_group = "puda_logger_cmd_requests"
  data_format = "json_v2"

  [inputs.nats_consumer.tags]
    msg_type = "command"
    status = "sent"

  [[inputs.nats_consumer.json_v2]]
    timestamp_path = "header.timestamp"
    timestamp_format = "2006-01-02T15:04:05Z07:00"
    timestamp_timezone = "UTC"

    [[inputs.nats_consumer.json_v2.tag]]
      path = "header.machine_id"
      rename = "machine_id"
    [[inputs.nats_consumer.json_v2.tag]]
      path = "header.username"
      rename = "username"
      optional = true
    [[inputs.nats_consumer.json_v2.tag]]
      path = "header.run_id"
      rename = "run_id"
      optional = true
    [[inputs.nats_consumer.json_v2.tag]]
      path = "command.name"
      rename = "cmd_name"
    [[inputs.nats_consumer.json_v2.field]]
      path = "header.user_id"
      rename = "user_id"
      optional = true
    [[inputs.nats_consumer.json_v2.field]]
      path = "command.step_number"
      rename = "step_number"
      type = "int"
    [[inputs.nats_consumer.json_v2.field]]
      path = "command.version"
      rename = "cmd_version"
      optional = true

# Command responses: puda.*.cmd.response.queue
[[inputs.nats_consumer]]
  name_override = "commands"
  servers = ${NATS_SERVERS}
  jetstream_subjects = ["puda.*.cmd.response.queue"]
  jetstream_stream = "RESPONSE_QUEUE"
