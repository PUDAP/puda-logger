# Telemetry: puda.*.tlm.health
# Wire format varies by machine; store the raw JSON payload as data.
[[inputs.nats_consumer]]
  name_override = "telemetry"
  servers = ${NATS_SERVERS}
  subjects = ["puda.*.tlm.health"]
  queue_group = "puda_logger_telemetry"
  data_format = "value"
  data_type = "string"

# Store raw telemetry JSON and use the payload timestamp when present.
[[processors.starlark]]
  namepass = ["telemetry"]
  source = '''
load("json.star", "json")
load("time.star", "time")

def apply(metric):
    raw = metric.fields.get("value")
    if raw == None:
        return metric

    metric.fields["data"] = raw
    metric.fields.pop("value")

    data = json.decode(raw)
    ts = data.get("timestamp")
    if type(ts) == "string" and len(ts) > 0:
        t = time.parse_time(ts, format="2006-01-02T15:04:05Z07:00", location="UTC")
        metric.time = t.unix_nano

    return metric
'''

# Derive topic from NATS subject: puda.first.cmd.response.queue -> response.queue
[[processors.regex]]
  namepass = ["commands"]
  [[processors.regex.tags]]
    key = "subject"
    pattern = '^puda\.[^.]+\.cmd\.(.+)$'
    replacement = "${1}"
    result_key = "topic"

# Derive machine_id from NATS subject: puda.first.tlm.health -> first
[[processors.regex]]
  namepass = ["telemetry"]
  [[processors.regex.tags]]
    key = "subject"
    pattern = '^puda\.([^.]+)\.tlm\.health$'
    replacement = "${1}"
    result_key = "machine_id"

[[outputs.influxdb_v2]]
  urls = ["${INFLUXDB_URL}"]
  token = "${INFLUXDB_TOKEN}"
  organization = "${INFLUXDB_ORGANIZATION}"
  bucket = "${INFLUXDB_DATABASE}"
