    [[inputs.nats_consumer.json_v2.tag]]
      path = "header.username"
      rename = "username"
      optional = true
    [[inputs.nats_consumer.json_v2.tag]]
      path = "header.run_id"
      rename = "run_id"
      optional = true
    [[inputs.nats_consumer.json_v2.tag]]
      path = "response.status"
      rename = "status"
      optional = true
    [[inputs.nats_consumer.json_v2.tag]]
      path = "command.name"
      rename = "cmd_name"
    [[inputs.nats_consumer.json_v2.field]]
      path = "header.user_id"
      rename = "user_id"
      optional = true
    [[inputs.nats_consumer.json_v2.field]]
      path = "command.step_number"
      rename = "step_number"
