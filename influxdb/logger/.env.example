# InfluxDB client
INFLUXDB_URL=http://bearsnas:8181
INFLUXDB_TOKEN=apiv3_puda
INFLUXDB_DATABASE=machines
INFLUXDB_WRITE_TIMEOUT_MS=5000

# NATS
NATS_SERVERS=nats://bears:4222,nats://bears:4223,nats://bears:4224
NATS_RECONNECT_WAIT_SECS=2

# Logger behaviour
HEALTH_STALL_TIMEOUT_SECS=90
TLM_WRITE_INTERVAL_SECS=5
WRITE_QUEUE_MAXSIZE=10000
LOG_LEVEL=INFO
